{
  "name": "@your-org/ui-library",
  "version": "0.1.0",
  "type": "module",
  "description": "A starter template for building your own React component library",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/component-library-starter"
  },
  "keywords": [
    "React",
    "TypeScript",
    "Storybook",
    "Design System",
    "Component Library",
    "Tailwind CSS"
  ],
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./dist/css/index.css": "./dist/css/index.css",
    "./dist/": {
      "import": "./dist/",
      "require": "./dist/"
    }
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "NODE_ENV=production rollup -c && yarn run build:postcss",
    "build:storybook": "storybook build",
    "build:postcss": "postcss src/css/variables/Tokens/index.css -o dist/css/index.css",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "format:write": "prettier --write '**/*.{js,ts,tsx,json,md,yml}' --ignore-path .prettierignore",
    "prepare": "husky install",
    "storybook": "storybook dev -p 6006 --quiet",
    "tailwind": "npx tailwindcss -i ./src/styles/tailwind-input.css -o ./src/styles/tailwind.css",
    "test": "NODE_ENV=test jest",
    "test:coverage": "NODE_ENV=test jest --coverage",
    "test:watch": "NODE_ENV=test jest --watch"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,mdx,yml,json}": [
      "prettier --write"
    ]
  },
  "browserslist": [
    "> 1%",
    "not dead",
    "not edge <= 18",
    "not ie 11",
    "not op_mini all"
  ],
  "dependencies": {
    "@babel/runtime": "^7.20.7",
    "react-is": "18"
  },
  "devDependencies": {
    "@babel/core": "^7.20.12",
    "@babel/plugin-transform-runtime": "^7.19.6",
    "@babel/preset-env": "^7.22.20",
    "@babel/preset-react": "^7.22.15",
    "@babel/preset-typescript": "^7.22.15",
    "@mdx-js/react": "^1.6.22",
    "@rollup/plugin-babel": "^6.0.3",
    "@rollup/plugin-commonjs": "^24.0.0",
    "@rollup/plugin-node-resolve": "^15.0.1",
    "@rollup/plugin-terser": "^0.3.0",
    "@rollup/plugin-url": "^8.0.1",
    "@storybook/addon-a11y": "^7.4.2",
    "@storybook/addon-actions": "^7.4.2",
    "@storybook/addon-designs": "^7.0.5",
    "@storybook/addon-essentials": "^7.4.2",
    "@storybook/addon-interactions": "^7.4.2",
    "@storybook/addon-links": "^7.4.2",
    "@storybook/addon-mdx-gfm": "^7.4.2",
    "@storybook/addon-styling": "1.3",
    "@storybook/addons": "^7.4.2",
    "@storybook/react": "^7.4.2",
    "@storybook/react-webpack5": "^7.4.2",
    "@storybook/testing-library": "^0.2.1",
    "@storybook/theming": "^7.4.2",
    "@svgr/rollup": "^8.1.0",
    "@svgr/webpack": "^8.1.0",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.4.3",
    "@trivago/prettier-plugin-sort-imports": "^4.0.0",
    "@types/jest": "^29.2.5",
    "@types/node": "^18.11.18",
    "@types/react": "^18.0.26",
    "@types/react-dom": "^18.0.10",
    "@types/styled-components": "^5.1.26",
    "@types/testing-library__jest-dom": "^5.14.5",
    "@typescript-eslint/eslint-plugin": "^5.48.1",
    "@typescript-eslint/parser": "^5.48.1",
    "@zerollup/ts-transform-paths": "^1.7.18",
    "autoprefixer": "^10.4.15",
    "babel-loader": "^9.1.2",
    "eslint": "8.31.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "^7.32.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-storybook": "^0.6.13",
    "eslint-plugin-testing-library": "^5.9.1",
    "husky": "^8.0.3",
    "jest": "^29.3.1",
    "jest-environment-jsdom": "^29.3.1",
    "jest-transform-stub": "^2.0.0",
    "lint-staged": "^13.1.0",
    "postcss": "^8.4.29",
    "postcss-cli": "^10.1.0",
    "postcss-import": "^15.1.0",
    "postcss-loader": "^7.3.3",
    "prettier": "^2.8.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rollup": "^2.79.1",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-delete": "^2.0.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-typescript2": "^0.34.1",
    "storybook": "^7.4.2",
    "tailwindcss": "^3.3.3",
    "ts-jest": "^29.0.4",
    "tslib": "^2.4.1",
    "ttypescript": "^1.5.15",
    "typescript": "^4.9.4",
    "typescript-transform-paths": "^3.4.6",
    "url-loader": "^4.1.1",
    "webpack": "^5.75.0",
    "webpack-cli": "^5.0.1"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17 || ^18",
    "react-dom": "^16.8.0 || ^17 || ^18"
  },
  "engines": {
    "node": ">=16"
  },
  "resolutions": {
    "jackspeak": "2.1.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
